GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
PORT=3000
MAX_FILE_SIZE_BYTES=209715200
TEMP_DIR=/tmp

# Gemini polling timing
# Formula: initialWait = ceil(fileSize / (UPLOAD_SPEED_MBPS * 125000)) + PROCESSING_BUFFER_SECONDS
# Capped at 180s (3 min). Increase UPLOAD_SPEED_MBPS if your server has faster outbound bandwidth.
GEMINI_UPLOAD_SPEED_MBPS=1
GEMINI_PROCESSING_BUFFER_SECONDS=30
